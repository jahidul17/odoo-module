<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="privilege_job_approval" model="res.groups.privilege">
            <field name="name">Job Approval Management</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_job_pm" model="res.groups">
            <field name="name">Project Manager</field>
            <field name="privilege_id" ref="job_published.privilege_job_approval"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_job_hr" model="res.groups">
            <field name="name">HR Approver</field>
            <field name="privilege_id" ref="job_published.privilege_job_approval"/>
            <field name="implied_ids" eval="[(4, ref('hr.group_hr_user'))]"/>
        </record>

        <record id="group_job_ceo" model="res.groups">
            <field name="name">CEO</field>
            <field name="privilege_id" ref="job_published.privilege_job_approval"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>