<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_inherit_asset" model="ir.ui.view">
        <field name="name">product.template.form.inherit.asset</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            
            <xpath expr="//div[@name='options']" position="inside">
               
                        <field name="is_asset" />
                        <label for="is_asset" string="Is an Asset?" class="ms-1 me-3"/>
    
            </xpath>

        </field>
    </record>
</odoo>