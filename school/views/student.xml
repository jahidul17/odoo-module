<odoo>

    <record id="view_student_list" model="ir.ui.view">
        <field name="name">school.student.list</field>
        <field name="model">student.model</field>
        <field name="arch" type="xml">
            <list>
                <field name="roll"/>
                <field name="name"/>
                <field name="gender"/>
            </list>
        </field>
    </record>

    <record id="action_school_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">student.model</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_student_form" model="ir.ui.view">
        <field name="name">school.student.form</field>
        <field name="model">student.model</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    
                    <!-- <div>
                        <h1>
                            <field name="roll"/>
                        </h1>
                    </div> -->
                    <!-- <group>
                        <field name="roll"/>
                        <field name="photo" widget="image" class="oe_avatar" options="{'preview_image':'photo'}"/>
                    </group> -->
                    <group>
                        <group>
                            <field name="roll"/>
                        </group>
                        <group>
                            <field name="photo" widget="image" class="oe_avatar" options="{'preview_image':'photo'}"/>
                        </group>
                        <group>
                            <field name="name"/>
                            <field name="birth_day"/>
                        </group>
                        <group>
                            <field name="gender"/>
                            <field name="address"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>

    </record>

    <menuitem id="menu_school_root" name="School Management"/>
    <menuitem id="menu_school_student" name="Students" parent="menu_school_root" action="action_school_student"/>

</odoo>



