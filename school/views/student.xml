<odoo>

    <record id="view_student_list" model="ir.ui.view">
        <field name="name">school.student.list</field>
        <field name="model">student.model</field>
        <field name="arch" type="xml">
            <list>
                <field name="roll"/>
                <field name="name"/>
                <field name="gender"/>
            </list>
        </field>
    </record>



    <record id="view_student_form" model="ir.ui.view">
        <field name="name">school.student.form</field>
        <field name="model">student.model</field>
        <field name="arch" type="xml">
            <form>
                <!-- Explore odoo CURD operations  -->
                <!-- <header>
                    <button name="explore_orm_operations" string="Explore ORM" type="object" class="oe_highlight" />
                </header> -->

                <header>
                    <button name="%(school.action_student_roll_update_wizard)d" 
                            string="Update Roll via Wizard" 
                            type="action" 
                            class="oe_highlight"/>
                        
                    <button name="action_enroll" string="Enroll Student" 
                            type="object" class="oe_highlight" 
                            invisible="state != 'draft'"/>
        
                    <button name="action_graduate" string="Graduate" 
                            type="object" invisible="state != 'enrolled'"/>

                    <button name="action_on_hold" string="Put on Hold" type="object" invisible="state != 'enrolled'"/>


                    <field name="state" widget="statusbar" statusbar_visible="draft,enrolled,graduated" options="{'clickable': '1'}"/>
                </header>
                
                <sheet>

                    <div class="oe_button_box" name="button_box">
                    <button name="action_view_classmates" 
                            type="object" 
                            class="oe_stat_button" 
                            icon="fa-graduation-cap">
                        <field name="classmate_count" widget="statinfo" string="Classmates"/>
                    </button>
                    </div>
                    
                    <!-- <div>
                        <h1>
                            <field name="roll"/>
                        </h1>
                    </div> -->
                    <!-- <group>
                        <field name="roll"/>
                        <field name="photo" widget="image" class="oe_avatar" options="{'preview_image':'photo'}"/>
                    </group> -->
                    <group>
                        <group>
                            <field name="roll"/>
                        </group>
                        <group>
                            <field name="photo" widget="image" class="oe_avatar" options="{'preview_image':'photo'}"/>
                        </group>
                        <group string="Basic Info">
                            <field name="name" help="Write your name"/>
                            <field name="birth_day"/>
                            <!-- <field name="additional_info" widget="ace" options="{'mode': 'python'}"/> -->
                        </group>
                        <group string="Optional Info">
                            <field name="gender"/>
                            <field name="division"/>
                            <field name="address"/>
                        </group>
                    </group>

                    <group string="Date Field">
                        <!-- <field name="joining_date"/> -->
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="joining_date" string="First Day" readonly="state == 'done'"/>
                    </group>

                    <!-- TEAM COMPOSITION -->
    
                    <group string="TEAM COMPOSITION">
                        <field name="team_member_ids" widget="many2many_list" nolabel="1" colspan="2">
                            <list editable="top">
                                <field name="name" style="min-width: 250px;"/>
                                <field name="roll"/>
                            </list>
                        </field>
                    </group>

                    <notebook>
                        <page string="About Student">
                            <field name="about_html" widget="html" options="{'collaborative': True, 'resizable': True}"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>

    </record>


    <record id="view_student_kanban" model="ir.ui.view">
        <field  name="name">student.kanban</field>
        <field name="model">student.model</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <!-- <div class="o_kanban_image">
                                <field name="photo" widget="image" class="oe_avatar"/>
                            </div> -->
                            <div class="oe_kanban_details">
                            <strong><field name="name"/></strong>
                            <ul>
                                <li>Roll:<field name="roll"/></li>
                                <li>Gender:<field name="gender"/></li>
                            </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_student_search" model="ir.ui.view">
        <field name="name">student.model.search</field>
        <field name="model">student.model</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Student Name"/>
                <field name="roll"/>

                <filter string="Male Students" name="male_filter" domain="[('gender', '=', 'male')]"/>
                <filter string="Female Students" name="female_filter" domain="[('gender', '=', 'female')]"/>
                
                <separator/> 

                
                <filter string="Gender" name="group_by_gender" context="{'group_by': 'gender'}"/>
                
            </search>
        </field>
    </record>

    <record id="action_school_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">student.model</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

</odoo>



