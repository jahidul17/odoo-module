<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- creating privilege -->
        <record id="privilege_school_management" model="res.groups.privilege">
            <field name="name">School Management</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_student" model="res.groups">
            <field name="name">Student</field>
            <field name="privilege_id" ref="privilege_school_management"/>
        </record>

        <!-- creating group -->
        <record id="group_teacher" model="res.groups">
            <field name="name">Teacher</field>
            <field name="privilege_id" ref="privilege_school_management"/>
        </record>

        <!-- creating group -->
        <record id="group_hr" model="res.groups">
            <field name="name">HR</field>
            <field name="privilege_id" ref="privilege_school_management"/>
        </record>

    </data>
</odoo>